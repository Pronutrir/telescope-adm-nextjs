{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Next.js: Server (SSR)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "env": {
                "NODE_OPTIONS": "--inspect"
            },
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal",
            "outputCapture": "std",
            "port": 9229
        },
        {
            "name": "Next.js: Client (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true
        },
        {
            "name": "Next.js: Full Stack",
            "type": "compound",
            "configurations": [
                "Next.js: Server (SSR)",
                "Next.js: Client (Chrome)"
            ]
        }
    ]
}
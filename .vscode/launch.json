{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 Next.js: Server (SSR)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "skipFiles": [
                "<node_internals>/**",
                "node_modules/**"
            ],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "- Local:.+(https?://.+)",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        },
        {
            "name": "🔧 Next.js: Server (Node Attach)",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "skipFiles": [
                "<node_internals>/**",
                "node_modules/**"
            ],
            "restart": true,
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ]
        },
        {
            "name": "🌐 Next.js: Client (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///./*": "${webRoot}/*",
                "webpack:///src/*": "${webRoot}/src/*",
                "webpack:///*": "*",
                "webpack:///./~/*": "${webRoot}/node_modules/*",
                "webpack:///./node_modules/*": "${webRoot}/node_modules/*"
            },
            "runtimeArgs": [
                "--remote-debugging-port=9222",
                "--disable-features=VizDisplayCompositor"
            ],
            "userDataDir": false,
            "trace": true
        },
        {
            "name": "🔍 Chrome: Attach to Running",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///./*": "${webRoot}/*",
                "webpack:///src/*": "${webRoot}/src/*",
                "webpack:///*": "*",
                "webpack:///./~/*": "${webRoot}/node_modules/*"
            },
            "trace": true
        }
    ],
    "compounds": [
        {
            "name": "🔄 Next.js: Full Stack",
            "configurations": [
                "🚀 Next.js: Server (SSR)",
                "🌐 Next.js: Client (Chrome)"
            ],
            "stopAll": true
        },
        {
            "name": "🔄 Next.js: Full Stack (Attach)",
            "configurations": [
                "🔧 Next.js: Server (Node Attach)",
                "🌐 Next.js: Client (Chrome)"
            ],
            "stopAll": true
        }
    ]
}
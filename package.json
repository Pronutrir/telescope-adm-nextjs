{
  "name": "telescope-adm-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "// ===== DEVELOPMENT SCRIPTS =====": "",
    "dev": "next dev --turbopack",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev --turbopack",
    "start": "next start",
    "// ===== CI/CD SCRIPTS (Sem dependências externas) =====": "",
    "build": "next build",
    "lint": "next lint",
    "test": "npm run test:ci",
    "test:unit": "jest --testPathPattern=tests/unit --coverage --watchAll=false",
    "test:integration": "jest --testPathPattern=tests/integration --coverage --watchAll=false",
    "test:ci": "npm run test:unit && npm run test:integration",
    "test:infrastructure": "jest --testPathPattern=tests/infrastructure --coverage --watchAll=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-unknown",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-unknown",
    "type-check": "npx tsc --noEmit",
    "ci:check": "tsx scripts/ci-setup-check.ts",
    "ci:setup": "npm run ci:check && echo 'Pipeline CI/CD pronto para uso!'",
    "// ===== INFRASTRUCTURE SCRIPTS (Com dependências externas) =====": "",
    "redis:test": "ts-node src/lib/redis-setup.ts test",
    "redis:clear": "ts-node src/lib/redis-setup.ts clear",
    "redis:stats": "ts-node src/lib/redis-setup.ts stats",
    "redis:setup": "ts-node src/lib/redis-setup.ts setup-prod",
    "redis:health": "tsx scripts/redis-health-check.ts once",
    "redis:monitor": "tsx scripts/redis-health-check.ts monitor",
    "redis:config": "tsx scripts/show-redis-config.ts",
    "redis:performance": "tsx src/tests/redis-validator.ts --performance",
    "test:redis": "tsx src/tests/redis-validator.ts",
    "test:redis:local": "tsx scripts/test-redis.ts local",
    "test:redis:prod": "tsx scripts/test-redis.ts production",
    "test:redis:all": "tsx scripts/test-redis.ts both",
    "// ===== E2E/API TESTING SCRIPTS =====": "",
    "test:auth": "node scripts/test-auth.js",
    "test:logout": "node scripts/test-logout.js",
    "test:server-ui": "node scripts/test-server-login-ui.js",
    "test:redirects": "node scripts/test-redirects.js",
    "test:api:health": "echo 'API health tests - to be implemented'",
    "test:webhooks:e2e": "echo 'Webhook E2E tests - to be implemented'",
    "// ===== INFRASTRUCTURE VALIDATION =====": "",
    "infra:validate": "npm run redis:health && npm run redis:config",
    "infra:test": "npm run test:redis:all"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@floating-ui/dom": "^1.7.6",
    "@microsoft/signalr": "^9.0.6",
    "@tanstack/react-query": "^5.84.1",
    "@tiptap/extension-placeholder": "^3.11.1",
    "@tiptap/extension-text-align": "^3.11.1",
    "@tiptap/extension-underline": "^3.11.1",
    "@tiptap/react": "^3.11.1",
    "@tiptap/starter-kit": "^3.11.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/sortablejs": "^1.15.8",
    "@types/uuid": "^10.0.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.5.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "downloadjs": "^1.4.7",
    "formik": "^2.4.6",
    "framer-motion": "^12.23.15",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.7.0",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.536.0",
    "moment": "^2.30.1",
    "mui-nested-menu": "^4.0.1",
    "next": "^15.5.4",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.54",
    "powerbi-client": "^2.23.9",
    "powerbi-client-react": "^2.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "react-pdf": "^10.0.1",
    "recharts": "^3.1.2",
    "sortablejs": "^1.15.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "yup": "^1.7.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/downloadjs": "^1.4.6",
    "@types/jest": "^29.5.14",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.14",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
